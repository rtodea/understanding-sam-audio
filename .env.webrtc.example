# Copy this file to .env and fill in your values.
# docker-compose reads .env automatically.

# ── Required ───────────────────────────────────────────────────────────────
# HuggingFace token — needed to download gated model checkpoints.
# Request access at: https://huggingface.co/facebook/sam-audio-large
HF_TOKEN=hf_your_token_here

# ── Ports ──────────────────────────────────────────────────────────────────
# Host port that NGINX binds to. Open http://localhost:${NGINX_PORT} in your browser.
NGINX_PORT=8080

# ── Model settings ─────────────────────────────────────────────────────────
# Model variant. Choose based on your GPU VRAM (check with: nvidia-smi).
#   facebook/sam-audio-small   (~4 GB VRAM)
#   facebook/sam-audio-base    (~6 GB VRAM)  ← default, fits RTX 4070 Laptop (8 GB)
#   facebook/sam-audio-large   (~9-11 GB VRAM, RTX 4070 Desktop / 4080+ only)
SAM_MODEL=facebook/sam-audio-base

# Number of separation candidates. Higher = better quality, more VRAM.
# RTX 4070 Laptop (8 GB): keep at 1 for base, or it may OOM.
SAM_RERANKING_CANDIDATES=1

# ── Streaming parameters ───────────────────────────────────────────────────
CHUNK_SECONDS=3.0
OVERLAP_SECONDS=1.5

# ── Device override (optional) ─────────────────────────────────────────────
# Leave empty for auto-detection (cuda if available, else cpu).
# Set to "cpu" to force CPU mode on macOS or machines without NVIDIA.
DEVICE=

# ── Azure Speech-to-Text (optional) ────────────────────────────────────────
# STT is disabled when AZURE_STT_KEY is empty.
AZURE_STT_KEY=
AZURE_STT_REGION=eastus
AZURE_STT_LANGUAGE=en-US